{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/comment-rot-hook.js\"",
            "commandWindows": "if (Get-Command node -ErrorAction SilentlyContinue) { node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\comment-rot-hook.js\" }",
            "timeout": 30,
            "statusMessage": "Scanning for comment rot..."
          }
        ]
      }
    ]
  }
}
